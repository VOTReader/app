{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "jsx": "react",
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": [
    "tools/globals.generated.d.ts",
    "app/src/main/assets/src/utils/**/*",
    "app/src/main/assets/src/stores/**/*",
    "app/src/main/assets/src/hooks/**/*",
    "app/src/main/assets/src/renderer/**/*",
    "app/src/main/assets/src/ui/**/*",
    "app/src/main/assets/src/components/**/*",
    "app/src/main/assets/src/data/scripture-resolution.js",
    "app/src/main/assets/src/data/journal-helpers.js",
    "app/src/main/assets/src/data/letter-linking.js",
    "app/src/main/assets/src/search/**/*"
  ],
  "exclude": [
    "app/src/main/assets/src/stores/_entry-b.js",
    "app/src/main/assets/src/renderer/_entry.js",
    "app/src/main/assets/src/ui/_entry-d.js",
    "app/src/main/assets/src/search/vendor/**"
  ]
}
