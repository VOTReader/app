#!/bin/sh
# pre-commit hook — six pre-flight checks gated on what's staged:
#
#   1. check_balance.py        when corpus data files change
#      Catches black-screen failure modes that brace-balance alone misses:
#      esprima parse errors, smart-quote delimiters, non-ASCII dashes in
#      verse ranges.
#   1b. validate-schemas.js --strict   when data files OR the validator change
#      (W9.1) Checks the Format A/B/C/D + Holy Days schemas: required
#      fields, block/segment/align types, footnote<->nkjv integrity,
#      prev/next chains, study chapterId resolution — the "valid JS but
#      invalid letter" class that check_balance.py can't see.
#
#   2. lint-staged (Q3.5)    when any .js/.jsx source file changes
#      Runs `eslint --max-warnings 0` ONLY on staged source files.
#      Mirrors CI's lint gate but in seconds (per-file, not full-repo),
#      so regressions fail at the commit-message prompt — not after push.
#      Config: package.json → "lint-staged" → eslint --max-warnings 0.
#
#   3. tsc --noEmit (Q4.1)   when any .js/.jsx source file changes
#      `npm run typecheck` against tsconfig.json's Q4 scope (utils +
#      stores + hooks). ~3.5s. tsc requires the whole project graph;
#      can't typecheck a single file in isolation, so we run the full
#      project on any source change. Zero-tolerance: any type error
#      fails the commit.
#
#   4. vitest run (Q5.1)     when any .js/.jsx source file changes
#      `npm run test` runs the full vitest suite once. ~2.3s for
#      the initial harness; will grow as Q5.2+ lands real tests.
#      jsdom environment; React-as-global + window.__* stubs in
#      vitest.setup.js. Zero-tolerance: any failing test fails the
#      commit.
#
#   5. python tools/build.py  when any bundle-source file changes
#      Rebuilds dist/bundle-{a,b,c,d}.js and stages the regenerated
#      output so the commit lands with bundles in sync with source.
#      Replaces the "remember to run the build" trap — the hook does
#      it for you. Runs ONLY on commits that touch bundle sources;
#      docs/gradle/plan commits skip it entirely.
#
#   6. gradle test (NK1)     when any .kt or app/build.gradle.kts changes
#      `./gradlew :app:testDebugUnitTest` runs the full Kotlin unit-test
#      suite (JUnit 5 + Robolectric, junit-vintage bridge). Zero-tolerance:
#      any failing Kotlin test fails the commit, same discipline as the
#      JS-side vitest gate. First run ~60s (Gradle daemon cold start);
#      subsequent ~5-10s with the daemon warm.
#
# This file is VERSIONED. To activate, run once per clone:
#   git config core.hooksPath .githooks
# (See CLAUDE.md for the one-line setup.)
#
# All five checks are skipped automatically when no relevant file is
# staged, so commits to CLAUDE.md / PLAN.txt / gradle files / etc. run
# without any delay.

exec 1>&2  # all output to stderr so it appears during commit

# Detect HEAD (first commit has no HEAD)
if git rev-parse --verify HEAD >/dev/null 2>&1; then
  against=HEAD
else
  against=$(git hash-object -t tree /dev/null)
fi

staged=$(git diff --cached --name-only "$against")

# ─── Step 1: corpus data file validation ────────────────────────────
data_changed=$(echo "$staged" | grep '^app/src/main/assets/src/data/' || true)
# Also run the schema validator when the validator OR its tests change, so a
# regression in tools/validate-schemas.js is caught even on a commit that
# stages no data file.
schema_tool_changed=$(echo "$staged" | grep -E '^tools/validate-schemas' || true)

if [ -n "$data_changed" ]; then
  echo "[pre-commit] Data files changed — running check_balance.py..."
  echo ""
  python check_balance.py
  status=$?
  if [ $status -ne 0 ]; then
    echo ""
    echo "---------------------------------------------------------------"
    echo "Data file validation FAILED — see output above."
    echo "Fix the errors, re-stage the file(s), then retry the commit."
    echo "  git add app/src/main/assets/src/data/<fixed-file>.js"
    echo "  git commit ..."
    echo "---------------------------------------------------------------"
    exit 1
  fi
  echo "[pre-commit] All data files OK."
  echo ""
fi

# ─── Step 1b: schema validation (W9.1 — Format A/B/C/D + Holy Days) ──
# node tools/validate-schemas.js --strict exits nonzero on any schema
# error (missing field, bad block/segment/align type, orphaned footnote
# ref, broken prev/next chain, unresolved study chapterId, …). Runs on
# data changes AND validator changes. Node may not be on the inherited
# PATH on Windows (winget install) — probe known install dirs, same
# pattern as the bundle-rebuild step below.
if [ -n "$data_changed" ] || [ -n "$schema_tool_changed" ]; then
  if ! command -v node >/dev/null 2>&1; then
    for candidate in \
        "/c/Program Files/nodejs" \
        "/c/Program Files (x86)/nodejs" \
        "$LOCALAPPDATA/Programs/Node.js" \
        "$HOME/AppData/Roaming/npm"; do
      if [ -x "$candidate/node" ] || [ -x "$candidate/node.exe" ]; then
        export PATH="$candidate:$PATH"
        break
      fi
    done
  fi
  echo "[pre-commit] Validating data schemas — node tools/validate-schemas.js --strict..."
  node tools/validate-schemas.js --strict
  status=$?
  if [ $status -ne 0 ]; then
    echo ""
    echo "---------------------------------------------------------------"
    echo "Schema validation FAILED — see errors above."
    echo "A data file has a structural error the parser can't catch:"
    echo "missing field, bad block/segment/align type, orphaned footnote"
    echo "ref, broken prev/next chain, or an unresolved study chapterId."
    echo "Fix the errors, re-stage the file(s), then retry the commit."
    echo "Emergency bypass (not recommended): git commit --no-verify"
    echo "---------------------------------------------------------------"
    exit 1
  fi
  echo "[pre-commit] Schema validation OK."
  echo ""
fi

# ─── Step 2: lint staged source files (Q3.5) ───────────────────────
# Mirrors CI's `npm run lint -- --max-warnings 0` gate but only on
# staged files. Sub-second on typical commits; fails fast at the commit
# prompt instead of after push.
src_changed=$(echo "$staged" | grep -E '^app/src/main/assets/src/.*\.(js|jsx)$' || true)

if [ -n "$src_changed" ]; then
  echo "[pre-commit] Source files staged — running lint-staged..."
  # Probe for npm on the path (winget-installed Node may not be on the
  # inherited PATH — mirrors the bundle-rebuild step's fallback).
  if ! command -v npm >/dev/null 2>&1; then
    for candidate in \
        "/c/Program Files/nodejs" \
        "/c/Program Files (x86)/nodejs" \
        "$LOCALAPPDATA/Programs/Node.js" \
        "$HOME/AppData/Roaming/npm"; do
      if [ -x "$candidate/npm" ] || [ -x "$candidate/npm.cmd" ]; then
        export PATH="$candidate:$PATH"
        break
      fi
    done
  fi
  npx lint-staged
  status=$?
  if [ $status -ne 0 ]; then
    echo ""
    echo "---------------------------------------------------------------"
    echo "Lint failed — see eslint output above."
    echo "Fix the warnings/errors, re-stage the file(s), then retry."
    echo "Emergency bypass (not recommended): git commit --no-verify"
    echo "---------------------------------------------------------------"
    exit 1
  fi
  echo "[pre-commit] Lint OK."
  echo ""

  # ─── Step 3: typecheck (Q4.1) ─────────────────────────────────────
  # Source files changed → run tsc --noEmit against the Q4 scope.
  # Reuses the npm path probe from above. ~3.5s for the full project.
  echo "[pre-commit] Source files staged — running tsc --noEmit (Q4 scope)..."
  npm run typecheck
  status=$?
  if [ $status -ne 0 ]; then
    echo ""
    echo "---------------------------------------------------------------"
    echo "Typecheck FAILED — see tsc output above."
    echo "Fix the type errors, re-stage the file(s), then retry."
    echo "Emergency bypass (not recommended): git commit --no-verify"
    echo "---------------------------------------------------------------"
    exit 1
  fi
  echo "[pre-commit] Typecheck OK."
  echo ""

  # ─── Step 4: vitest run (Q5.1) ────────────────────────────────────
  # Source files changed → run the full vitest suite. Fast for now
  # (~2.3s); grows as Q5.2+ adds real tests. Zero-tolerance.
  echo "[pre-commit] Source files staged — running vitest..."
  npm run test
  status=$?
  if [ $status -ne 0 ]; then
    echo ""
    echo "---------------------------------------------------------------"
    echo "Tests FAILED — see vitest output above."
    echo "Fix the failing tests, re-stage the file(s), then retry."
    echo "Emergency bypass (not recommended): git commit --no-verify"
    echo "---------------------------------------------------------------"
    exit 1
  fi
  echo "[pre-commit] Tests OK."
  echo ""

  # ─── App() size budget (P11 canary) ──────────────────────────────
  # If app.jsx itself is staged, enforce its line budget — the composition
  # root must stay decomposed (new concerns belong in src/hooks/, not
  # inlined). Catches the drift class lint/type/test/build don't: app.jsx
  # crept 797->838 lines unnoticed before this gate existed.
  app_jsx_changed=$(echo "$staged" | grep -E '^app/src/main/assets/src/app\.jsx$' || true)
  if [ -n "$app_jsx_changed" ]; then
    npm run check:app-size
    status=$?
    if [ $status -ne 0 ]; then
      echo ""
      echo "---------------------------------------------------------------"
      echo "App() size budget exceeded — extract a concern into src/hooks/."
      echo "Emergency bypass (not recommended): git commit --no-verify"
      echo "---------------------------------------------------------------"
      exit 1
    fi
    echo "[pre-commit] App() size OK."
    echo ""
  fi
fi

# ─── Step 5: bundle rebuild + SW cache version ──────────────────────
# Any change to a bundled source OR a core-cached asset (app.css,
# index.html) means dist/bundle-*.js and/or the SW's content-hash
# CACHE_VERSION is stale. `npm run build` rebuilds the bundles AND
# re-derives CACHE_VERSION from the core-asset hash (build:sw), so we
# re-stage the bundles + service-worker.js together. Triggers:
#   - app/src/main/assets/src/**/*.{js,jsx}  (all extracted modules)
#   - search.js, search-data.js, flexsearch.min.js
#   - react.min.js, react-dom.min.js, html2canvas.min.js
#   - app.css, index.html  (core-cached → feed the SW content hash)
bundle_source_changed=$(echo "$staged" | grep -E '^app/src/main/assets/(src/.*\.js|src/.*\.jsx|search\.js|search-data\.js|flexsearch\.min\.js|react\.min\.js|react-dom\.min\.js|html2canvas\.min\.js|app\.css|index\.html)$' || true)

if [ -n "$bundle_source_changed" ]; then
  echo "[pre-commit] Bundle source files changed — rebuilding dist/bundle-*.js..."
  # `npm run build` chains both bundlers in one command:
  #   1. python tools/build.py  → bundle-a.js (classic-script concat)
  #   2. esbuild                → bundle-b.js (G.2.2), bundle-c.js (G.2.1), bundle-d.js (G.2.3)
  # All four must succeed before we stage.
  #
  # All four bundles rebuild + re-stage every time, so a commit can include
  # changes to bundles whose source you did not edit — the hook normalizes
  # any previously-stale bundle here. That extra diff is intentional.
  #
  # Node is required on PATH for the esbuild half. The original assumption
  # was that git-bash on Windows inherits the system PATH containing
  # C:\Program Files\nodejs (the winget install location). In practice
  # that's not always true — winget installs don't refresh PATH for
  # already-running shells, and git-bash invoked from File Explorer /
  # an IDE inherits the parent process's PATH, which may pre-date the
  # Node install. So we probe known install locations and prepend the
  # first one that exists.
  if ! command -v npm >/dev/null 2>&1; then
    for candidate in \
        "/c/Program Files/nodejs" \
        "/c/Program Files (x86)/nodejs" \
        "$LOCALAPPDATA/Programs/Node.js" \
        "$HOME/AppData/Roaming/npm"; do
      if [ -x "$candidate/npm" ] || [ -x "$candidate/npm.cmd" ]; then
        export PATH="$candidate:$PATH"
        echo "[pre-commit] Added $candidate to PATH (npm not on inherited PATH)"
        break
      fi
    done
  fi
  npm run build
  status=$?
  if [ $status -ne 0 ]; then
    echo ""
    echo "---------------------------------------------------------------"
    echo "Bundle rebuild FAILED — see output above."
    echo "If npm or node is missing, install Node LTS from nodejs.org"
    echo "(or via winget install OpenJS.NodeJS.LTS) and try again."
    echo "Fix the build error, re-stage, then retry the commit."
    echo "---------------------------------------------------------------"
    exit 1
  fi
  # Stage the regenerated bundles + the re-versioned SW so the commit
  # lands with everything in sync.
  # Stage ALL seven bundles, incl. the lazy corpus bundles (a-bible /
  # a-matthew / a-vot) — a data-file edit (books.js, matthew.js, a VOT
  # corpus) regenerates those, and they're tracked, so they must be
  # re-staged or the committed bundle goes stale (CI bundle-match fails +
  # the app ships old data). `git add` of an unchanged bundle is a no-op,
  # so listing them is safe on non-corpus commits.
  git add app/src/main/assets/dist/bundle-a.js \
          app/src/main/assets/dist/bundle-a-bible.js \
          app/src/main/assets/dist/bundle-a-matthew.js \
          app/src/main/assets/dist/bundle-a-vot.js \
          app/src/main/assets/dist/bundle-b.js \
          app/src/main/assets/dist/bundle-c.js \
          app/src/main/assets/dist/bundle-d.js \
          app/src/main/assets/service-worker.js
  echo "[pre-commit] Bundles + SW cache version regenerated and staged."
fi

# ─── Step 6: gradle test (NK1) ──────────────────────────────────────
# Any change to a .kt source file or the app/build.gradle.kts means the
# Kotlin unit-test suite needs to run. Mirrors the JS-side vitest gate
# in zero-tolerance discipline. First run cold-starts the Gradle daemon
# (~60s); subsequent runs are ~5-10s with the daemon warm.
#
# We test on test-source changes too — a flaky test file or a new test
# that breaks the suite should fail at the commit prompt, not in CI.
kotlin_changed=$(echo "$staged" | grep -E '^(app/src/(main|test)/.*\.kt|app/build\.gradle\.kts|gradle/libs\.versions\.toml)$' || true)

if [ -n "$kotlin_changed" ]; then
  echo "[pre-commit] Kotlin sources or gradle config changed — running ./gradlew :app:testDebugUnitTest..."
  if [ -x ./gradlew ]; then
    GRADLE_CMD="./gradlew"
  elif command -v gradle >/dev/null 2>&1; then
    GRADLE_CMD="gradle"
  else
    echo "---------------------------------------------------------------"
    echo "Neither ./gradlew nor gradle on PATH. Cannot run Kotlin tests."
    echo "If you intentionally do not have Gradle locally, use:"
    echo "  git commit --no-verify"
    echo "and the CI gate will catch any test failures on push."
    echo "---------------------------------------------------------------"
    exit 1
  fi
  $GRADLE_CMD :app:testDebugUnitTest :app:jacocoTestCoverageVerification
  status=$?
  if [ $status -ne 0 ]; then
    echo ""
    echo "---------------------------------------------------------------"
    echo "Kotlin tests OR coverage gate FAILED — see gradle output above."
    echo "HTML test report: app/build/reports/tests/testDebugUnitTest/index.html"
    echo "HTML coverage report:"
    echo "  app/build/reports/jacoco/jacocoTestReport/html/index.html"
    echo "  (run \`./gradlew :app:jacocoTestReport\` first if missing)"
    echo "Fix the failing tests, re-stage, then retry the commit."
    echo "Emergency bypass (not recommended): git commit --no-verify"
    echo "---------------------------------------------------------------"
    exit 1
  fi
  echo "[pre-commit] Kotlin tests + coverage gate OK."
fi

exit 0
