{
  "name": "votreader-build",
  "version": "1.0.2",
  "description": "Build pipeline for VOTReader's WebView assets (Objective G â€” bundler + ES modules).",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "python tools/build.py && npm run build:b && npm run build:c && npm run build:d && npm run build:css && npm run build:csp && npm run build:sw",
    "build:b": "esbuild app/src/main/assets/src/stores/_entry-b.js --bundle --format=iife --target=chrome69 --minify --outfile=app/src/main/assets/dist/bundle-b.js",
    "build:c": "esbuild app/src/main/assets/src/renderer/_entry.js --bundle --format=iife --target=chrome69 --minify --outfile=app/src/main/assets/dist/bundle-c.js",
    "build:d": "esbuild app/src/main/assets/src/ui/_entry-d.js --bundle --format=iife --target=chrome69 --minify --outfile=app/src/main/assets/dist/bundle-d.js",
    "build:css": "esbuild app/src/main/assets/app.css --minify --target=chrome69 --outfile=app/src/main/assets/dist/app.min.css",
    "build:csp": "node tools/sync-csp-hashes.js",
    "build:sw": "node tools/sync-sw-version.js",
    "check:csp": "node tools/sync-csp-hashes.js --check",
    "typecheck": "tsc --noEmit",
    "jsx-progress": "python tools/jsx-progress.py",
    "lint:globals": "python tools/gen-eslint-globals.py",
    "lint": "npm run lint:globals && eslint app/src/main/assets/src",
    "lint:fix": "npm run lint:globals && eslint app/src/main/assets/src --fix",
    "smoke-lite": "node tools/smoke-lite.js",
    "smoke:ci": "node tools/smoke-ci.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "validate:data": "node tools/validate-schemas.js --strict",
    "check:app-size": "node tools/check-app-size.js",
    "check:corpus": "node tools/check-corpus-version.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.7",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.5",
    "puppeteer": "^25.1.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "lint-staged": {
    "app/src/main/assets/src/**/*.{js,jsx}": "eslint --max-warnings 0 --no-warn-ignored"
  },
  "engines": {
    "node": ">=20"
  }
}
