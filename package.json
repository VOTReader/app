{
  "name": "votreader-build",
  "version": "0.0.0",
  "description": "Build pipeline for VOTReader's WebView assets (Objective G â€” bundler + ES modules).",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "python tools/build.py && npm run build:b && npm run build:c && npm run build:d",
    "build:b": "esbuild app/src/main/assets/src/stores/_entry-b.js --bundle --format=iife --outfile=app/src/main/assets/dist/bundle-b.js",
    "build:c": "esbuild app/src/main/assets/src/renderer/_entry.js --bundle --format=iife --outfile=app/src/main/assets/dist/bundle-c.js",
    "build:d": "esbuild app/src/main/assets/src/ui/_entry-d.js --bundle --format=iife --outfile=app/src/main/assets/dist/bundle-d.js",
    "typecheck": "tsc --noEmit",
    "jsx-progress": "python tools/jsx-progress.py",
    "lint:globals": "python tools/gen-eslint-globals.py",
    "lint": "npm run lint:globals && eslint app/src/main/assets/src",
    "lint:fix": "npm run lint:globals && eslint app/src/main/assets/src --fix"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "lint-staged": "^17.0.5",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "app/src/main/assets/src/**/*.{js,jsx}": "eslint --max-warnings 0"
  },
  "engines": {
    "node": ">=20"
  }
}
