<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.VotReader" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Splash theme — used as the launch theme so cold-boot shows a
         branded icon on black instead of a white/system-default flash before
         the WebView paints. After installSplashScreen() dismisses, the
         activity transitions to Theme.VotReader (postSplashScreenTheme).
         core-splashscreen backports this to API 23+; we target 26+. -->
    <style name="Theme.VotReader.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@android:color/black</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.VotReader</item>
    </style>
</resources>
