<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Microphone — required for in-app voice recording (journal voice memos).
         Runtime permission is requested via ActivityResultContracts.RequestPermission
         on API 23+. WebChromeClient.onPermissionRequest grants the WebView
         RESOURCE_AUDIO_CAPTURE once the OS grant is in place. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- MODIFY_AUDIO_SETTINGS — a "normal" (non-runtime) permission. WebView's
         internal Chromium audio pipeline calls AudioManager.setMode() when it
         opens an AudioRecord session for getUserMedia. Without this permission
         that call silently no-ops, the audio subsystem stays in the wrong mode,
         AudioRecord fails to acquire the mic, and getUserMedia rejects with
         NotReadableError even though RECORD_AUDIO is granted and no other app
         is recording. Required for in-app voice recording to work on Android. -->
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <uses-feature android:name="android.hardware.microphone" android:required="false" />

    <application
        android:name=".VOTReaderApp"
        android:allowBackup="false"
        android:hardwareAccelerated="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.VotReader.Splash">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:configChanges="screenSize|orientation|keyboardHidden|smallestScreenSize|uiMode|screenLayout"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>
